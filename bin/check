#!/usr/bin/env bash
# Exactly what CI runs (.github/workflows/ci.yml): build, test, clippy.
# Green here means green there. CI's clippy is report-only (style-level lint
# debt is tracked separately), so this doesn't fail on lint warnings — the
# build and the tests are the gate.
set -euo pipefail
cd "$(dirname "$0")/.."

echo "── cargo build --workspace"
cargo build --workspace

echo "── cargo test --workspace"
cargo test --workspace

echo "── cargo clippy --workspace (report-only, like CI)"
cargo clippy --workspace || true

echo "check: build + tests green"
