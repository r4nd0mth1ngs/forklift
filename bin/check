#!/usr/bin/env bash
# Exactly what CI runs (.github/workflows/ci.yml): build, test, clippy.
# Green here means green there. CI's clippy is report-only (style-level lint
# debt is tracked separately), so this doesn't fail on lint warnings — the
# build and the tests are the gate.
set -euo pipefail
cd "$(dirname "$0")/.."

echo "── cargo build --workspace"
cargo build --workspace

echo "── cargo test --workspace"
cargo test --workspace

echo "── cargo clippy --workspace (report-only, like CI)"
cargo clippy --workspace || true

echo "── docs freshness (bin/gen-docs)"
# Regenerate into a scratch directory (never touching docs/generated in place) and diff —
# catches both stale content and a deleted generated file, without side effects on a green run.
docs_scratch="$(mktemp -d)"
trap 'rm -rf "$docs_scratch"' EXIT
./bin/gen-docs "$docs_scratch" >/dev/null
if ! diff -ru docs/generated "$docs_scratch"; then
    echo
    echo "docs/generated/ is stale — run ./bin/gen-docs and commit the result." >&2
    exit 1
fi

echo "check: build + tests + docs green"
