# Forklift ignore file.
# This file is used to specify files and directories that should be ignored by Forklift.
# Every entry must be a valid regex pattern.
#
# Example - ignore a folder called "test":
# ^test\/?.*$
#
# Example - ignore all files with the extension ".log":
# \.log$

# Target directory generated by cargo.
^target\/?.*$

# IntelliJ IDEA project files.
^\.idea\/?.*$

# Git directory (as currently git is used for version control).
^\.git\/?.*$

# Claude Code state: ephemeral worktrees, jobs and scratch (mirrors .gitignore's .claude/).
# Without this the dogfood post-commit hook loads whole worktree copies — build output and all.
^\.claude\/?.*$

# Scratch dev warehouse used by `bin/serve` (pult serve).
^\.dev\/?.*$

# macOS Finder metadata, at any depth.
\.DS_Store$

# The Forklift directory does not have to be ignored explicitly, as it is ignored by default.